{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "fullName": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "dob": { "type": "string" },
        "village": { "type": "string" },
        "nid": { "type": "string" },
        "password": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["memberId", "fullName", "mobile", "dob", "village", "password"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    }
  }
}
