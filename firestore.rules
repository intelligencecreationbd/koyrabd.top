rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "intelligencecreationbd@gmail.com" && request.auth.token.email_verified == true));
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      // Allow read for everyone so login and community chat work.
      // WARNING: This collection currently contains passwords in plain text.
      // This is a major security risk. Passwords should be hashed or moved to a private collection.
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();

      // Digital Ledger subcollection
      match /ledgers/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // App settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banner_categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Chat related
    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /friends/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /requests_outgoing/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /requests_incoming/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if isAuthenticated();
    }

    match /user_rooms/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if isAuthenticated();
    }

    match /messages/{chatId}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /typing/{typingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Helpline
    match /helpline_messages/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // News & Posts
    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news_main/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /breaking_news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news_pending/{docId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    match /news_rejected/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /posts/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Mobile Directory
    match /contacts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // House Rentals
    match /house_rentals/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Bengali Collection Names
    match /{collectionName}/{document=**} {
      allow read: if collectionName in ['হটলাইন', 'বাস', 'আইনি সেবা', 'চিকিৎসা সেবা', 'পণ্য', 'ক্যাটাগরি'];
      allow write: if isAdmin() || (collectionName in ['পণ্য', 'চিকিৎসা সেবা'] && isAuthenticated());
    }
  }
}
