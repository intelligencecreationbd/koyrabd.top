rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to 'হটলাইন' and 'settings' collections
    match /হটলাইন/{document=**} {
      allow read: if true;
      allow write: if false; // Only admin should write via Firebase Console or Admin SDK
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /helpline_messages/{document=**} {
      allow read, write: if request.auth != null || request.resource.data.chatId != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
