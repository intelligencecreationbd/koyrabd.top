# .env.example
# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
GEMINI_API_KEY=

# Google Analytics 4 (GA4) Credentials
# Find Property ID in GA4 Admin > Property Settings
GA_PROPERTY_ID=
# Create Service Account in Google Cloud Console > IAM & Admin > Service Accounts
GA_CLIENT_EMAIL=
# Download JSON key and copy the private_key field (include \n)
GA_PRIVATE_KEY=
